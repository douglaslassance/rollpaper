# Local secrets for trigger scripts. Copy to `.env` (gitignored) at the app
# repo root and fill in values. CI does NOT read this file — set the same
# names as GitHub Actions secrets there.
#
# Vars marked [optional] can be omitted entirely; the relevant step degrades
# gracefully (e.g. unsigned ad-hoc build instead of notarized).

# === Code signing (direct distribution: scripts/build.sh, build-tauri.sh) ===
# Developer ID Application certificate from Keychain.
# e.g. "Developer ID Application: Your Name (XXXXXXXXXX)"
APPLE_SIGNING_IDENTITY=

# === Notarization (scripts/build.sh, build-tauri.sh, upload-appstore.sh) ===
# Apple API key from App Store Connect > Users & Access > Integrations > API Keys
NOTARIZATION_KEY_ID=
NOTARIZATION_ISSUER_ID=
# Contents of the .p8 file, base64-encoded
# e.g. base64 -i AuthKey_XXXXXXXXXX.p8 | tr -d '\n'
NOTARIZATION_KEY=

# === Sparkle [optional: only if [sparkle] section in trigger.toml] ===
# Generate once with: .build/artifacts/sparkle/Sparkle/bin/generate_keys
SPARKLE_PUBLIC_KEY=
# Private key for signing releases; base64-encoded. If empty, sign_update
# falls back to the macOS keychain.
SPARKLE_PRIVATE_KEY=

# === Cloudflare R2 [required if [r2] section in trigger.toml] ===
# Cloudflare Dashboard > R2 > Manage R2 API tokens
S3_ACCOUNT_ID=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
# Public URL for the bucket, no trailing slash; used for cache purge.
# e.g. https://s3.douglaslassance.me
S3_PUBLIC_URL=

# === Cloudflare KV [optional: drives Homebrew livecheck] ===
# Cloudflare Dashboard > Workers & Pages > KV (or: wrangler kv namespace list)
CLOUDFLARE_KV_NAMESPACE_ID=

# === Cloudflare cache purge [optional] ===
# Without these, the CDN may serve stale files after an upload.
CLOUDFLARE_ZONE_ID=
# API token needs: KV Storage Write + Cache Purge permissions
CLOUDFLARE_API_TOKEN=

# === Homebrew tap [required if [homebrew] section in trigger.toml] ===
# Personal access token with repo scope: github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=
# Homebrew tap git URL — defaults to Homebrew/homebrew-cask
# e.g. https://github.com/douglaslassance/homebrew-tap.git
HOMEBREW_TAP_URL=
